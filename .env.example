# Vocabulary Quest — Local Development Environment Variables
# Copy this file to .env and fill in your keys
# Never commit .env to version control

# Your Anthropic API key (from console.anthropic.com → API Keys)
# Required for word suggestions, quiz generation, and Story Bible
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here

# Your Gemini API key (from aistudio.google.com → API Keys)
# Required for live image generation when running locally
# In the Claude artifact, images are handled via the tarball workflow instead
VITE_GEMINI_API_KEY=AIza-your-key-here
