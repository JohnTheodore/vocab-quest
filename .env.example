# Your Gemini API key (from aistudio.google.com → API Keys)
# Required for image generation
GEMINI_API_KEY=AIza-your-key-here

# Optional: password-protect the app in single-user (legacy) mode.
# Not needed once you've run /setup to create multi-user accounts.
# AUTH_PASSWORD=your-password-here

# Optional: secret key for signing session cookies in multi-user mode.
# If not set, falls back to AUTH_PASSWORD, then to an auto-generated secret
# persisted in data/.session-secret (survives redeploys).
# SESSION_SECRET=your-secret-here

# Optional: Resend API key for transactional email (password reset).
# Sign up at resend.com and create an API key.
# RESEND_API_KEY=re_...

# Optional: the public URL of your app (used in password reset links).
# Defaults to http://localhost:5173 in dev.
# APP_URL=https://vocabquest.app

# Optional: the "from" address for transactional email.
# Must be a verified domain in Resend. Defaults to onboarding@resend.dev.
# EMAIL_FROM=noreply@vocabquest.app

# Optional: Claude OAuth token for headless environments (e.g. Railway)
# Not needed if you've run `claude login` locally
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
